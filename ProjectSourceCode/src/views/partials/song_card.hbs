<a href="/songs/{{id}}" style="text-decoration: none; color: inherit; flex: 0 0 auto;">
    <div class="card h-100 song-card" style="width: 12rem; cursor: pointer;">
        {{#if album.images.[0].url}}
            <img src="{{album.images.[0].url}}" class="card-img-top" alt="{{album.name}}" style="border-bottom: 1px solid #e0e0e0;">
        {{/if}}
        <div class="card-body d-flex flex-column" style="overflow: visible;">
            <h5 class="card-title" style="display: -webkit-box; -webkit-line-clamp: 2; 
            -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 1rem; line-height: 1.4; 
            padding-bottom: 0.1rem; word-break: break-word; word-wrap: break-word;">{{name}}</h5>
            <div style="flex-grow: 1;"></div>
            {{#if album.name}}
            <p class="card-text small" style="margin-bottom: 0.5rem; overflow: visible;">{{album.name}}</p>
            {{/if}}
            <p class="card-text text-muted" style="margin-bottom: 0; overflow: visible;">
                {{#each artists}}
                    {{#if @index}}, {{/if}}{{this.name}}
                {{/each}}
            </p>
        </div>
    </div>
</a>