<header>
  <div class="d-flex flex-column flex-shrink-0 p-3 bg-light" style="width: 280px; height: 100vh; position: fixed; top: 0; left: 0;">
    <a href="/" class="d-flex justify-content-center w-100 text-decoration-none link-dark">
      <i class="bi bi-card-image"></i>
      <div class="d-flex flex-column align-items-center text-center">
        <span class="fs-4">ATrack</span>
        <small class="logo-subtext text-muted" style="margin-top: -4px;">for music</small>
      </div>
    </a>
    <hr>

<form class="navbar-form navbar-left mb-3" action="/search" method="GET">
  <div class="input-group">

    <!-- DROPDOWN -->
    <select name="type" class="form-select px-2" style="max-width: 90px; background-color: #dee2e6" >
      <option value="track">Tracks</option>
      <option value="artist">Artists</option>
      <option value="album">Albums</option>
      <option value="users">Users</option>
    </select>

    <!-- SEARCH ICON -->
    <span class="input-group-text bg-white border-start-0 border-end-0">
      <i class="bi bi-search"></i>
    </span>

    <!-- MAIN INPUT -->
    <input 
      type="text" 
      class="form-control" 
      name="song" 
      placeholder="Search..." 
      required
    >

  </div>
</form>

<!-- NAV LINKS -->
<ul class="nav nav-pills flex-column mb-auto">
  <li class="nav-item">
    <a href="/albums" class="nav-link link-dark {{#if isAlbums}}active{{/if}}">
      <i class="bi bi-vinyl-fill"></i>
      Albums
    </a>
  </li>
  <li>
    <a href="/songs" class="nav-link link-dark {{#if isSongs}}active{{/if}}">
      <i class="bi bi-music-note-beamed"></i>
      Songs
    </a>
  </li>
  <li>
    <a href="/genres" class="nav-link link-dark {{#if isGenres}}active{{/if}}">
      <i class="bi bi-music-note-list"></i>
      Genres
    </a>
  </li>
  <li>
    <a href="/friends" class="nav-link link-dark {{#if isFriends}}active{{/if}}">
      <i class="bi bi-people-fill"></i>
      Friends
    </a>
  </li>
</ul>
      {{#if user}}
        <div class="profile-card" style="position: relative;">
          <div id="profileMenu" style="display: none; position: absolute; bottom: 100%; left: 0; right: 0; background: white; border: 1px solid #dee2e6; border-radius: 8px; box-shadow: 0 -2px 8px rgba(0,0,0,0.1); z-index: 1000; margin-bottom: 8px;">
            <a href="/profile" class="dropdown-item" style="display: block; padding: 12px 15px; text-decoration: none; color: #333; border-bottom: 1px solid #dee2e6; cursor: pointer; font-size: 14px;">
              <i class="bi bi-person"></i> Profile
            </a>
            <a href="/logout" class="dropdown-item" style="display: block; padding: 12px 15px; text-decoration: none; color: #dc3545; cursor: pointer; font-size: 14px;">
              <i class="bi bi-box-arrow-right"></i> Logout
            </a>
          </div>
          
          <button 
            class="btn d-flex align-items-center gap-2 p-2" 
            style="background: none; border: none; cursor: pointer; width: 100%; justify-content: flex-start;"
            onclick="toggleProfileMenu()"
          >
            <img 
              src="/resources/img/default-profile.png" 
              alt="Profile" 
              class="profile-pic" 
              style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover; flex-shrink: 0;"
            >
            <span class="text-dark" style="word-break: break-word; font-weight: 600; font-size: 18px; text-align: left; margin-left: 8px;">{{user.username}}</span>
          </button>
        </div>
      {{else}}
        <div class="d-grid gap-2">
          <a class="btn btn-outline-primary rounded-0" href="/login" role="button">Log In</a>
          <a class="btn btn-primary rounded-0" href="/register" role="button">Sign Up Free</a>
        </div>
      {{/if}}
    </header>