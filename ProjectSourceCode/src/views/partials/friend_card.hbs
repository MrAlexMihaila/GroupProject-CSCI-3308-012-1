<div class="col">
    <div
    class="card h-100 shadow-sm" role="link" tabindex="0" onclick="window.location.href='/profile/{{user_id}}'"
    onkeydown="if (event.key === 'Enter') window.location.href='/profile/{{user_id}}'" style="cursor: pointer;"
    >
    <div class="card-body d-flex flex-column">
        {{#if user_image_url}}
        <img src="{{user_image_url}}" class="card-img-top mb-3" alt="{{username}}'s profile picture" style="height: 300px; object-fit: cover;">
        {{else}}
        <img src="/resources/img/default-profile.png" class="card-img-top mb-3" alt="Default profile picture" style="height: 300px; object-fit: cover;">
        {{/if}}
        <h5 class="card-title">{{username}}</h5>
        
        <p class="card-text text-muted mb-1">Friends: {{friend_count}}</p>
        <p class="card-text text-muted mb-1">Followers: {{follower_count}}</p>
        <p class="card-text text-muted mb-3">Joined: {{created_at}}</p>

        
        {{#if isFollowing}}
            
        {{else}}
            <form method="POST" action="/friends/follow" class="mt-auto" onclick="event.stopPropagation();">
                <input type="hidden" name="followedId" value="{{user_id}}" />
                <input type="hidden" name="search" value="{{search}}" />
                <button type="submit" class="btn btn-primary w-100">Follow</button>
            </form>
        {{/if}}
    </div>
    </div>
</div>