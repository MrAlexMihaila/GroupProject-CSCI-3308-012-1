<a href="/artist/{{id}}" class="text-decoration-none text-dark">
  <div class="card h-100 border-0 artist-card text-center p-3">

    <!-- Image -->
    {{#if images.[0].url}}
      <img src="{{images.[0].url}}"
           class="rounded-circle mx-auto"
           style="width: 120px; height: 120px; object-fit: cover;">
    {{else}}
      <div class="bg-secondary text-white rounded-circle mx-auto d-flex align-items-center justify-content-center"
           style="width: 120px; height: 120px;">
        ?
      </div>
    {{/if}}

    <!-- Content -->
    <div class="mt-3">

      <!-- Name -->
      <h6 class="fw-semibold mb-1">{{name}}</h6>

      <!-- Followers -->
      {{#if followers.total}}
        <p class="text-muted small mb-1">
          {{formatNumber followers.total}} followers
        </p>
      {{/if}}

      <!-- Genre -->
      {{#if genres.[0]}}
        <p class="text-muted small mb-0">
          {{genres.[0]}}
        </p>
      {{/if}}

    </div>
  </div>
</a>