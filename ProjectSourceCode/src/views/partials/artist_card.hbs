<a href="/artist/{{id}}" style="text-decoration: none; color: inherit;">
  <div class="card h-100 artist-card" style="min-width: 12rem; flex: 0 1 calc(20% - 0.6rem); cursor: pointer;">

    {{#if images.[0].url}}
      <img src="{{images.[0].url}}" class="card-img-top" alt="{{name}}" style="border-bottom: 1px solid #e0e0e0;">
    {{/if}}

    <div class="card-body d-flex flex-column" style="overflow: visible;">

      <!-- Artist Name -->
      <h5 class="card-title"
          style="display: -webkit-box; -webkit-line-clamp: 2;
          -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 1rem;
          line-height: 1.4; padding-bottom: 0.1rem; word-break: break-word;">
        {{name}}
      </h5>

      <div style="flex-grow: 1;"></div>

      <!-- Followers -->
      {{#if followers.total}}
        <p class="card-text small" style="margin-bottom: 0.5rem;">
          Followers: {{followers.total}}
        </p>
      {{/if}}

      <!-- Genre -->
      <p class="card-text text-muted" style="margin-bottom: 0;">
        {{#if genres.[0]}}
          {{genres.[0]}}
        {{else}}
          Unknown Genre
        {{/if}}
      </p>

    </div>
  </div>
</a>