<a href="/artist/{{id}}" class="text-decoration-none text-dark">
  <div class="card h-100 artist-card border-0 text-center p-4">

    <!-- Artist Image -->
    {{#if images.[0].url}}
      <img src="{{images.[0].url}}" class="artist-img">
    {{else}}
      <div class="artist-img bg-secondary text-white d-flex align-items-center justify-content-center">
        ?
      </div>
    {{/if}}

    <!-- Content -->
    <div class="mt-3">

      <!-- Name -->
      <h6 class="fw-semibold mb-1 text-truncate-2">
        {{name}}
      </h6>

      <!-- Followers -->
      {{#if followers.total}}
        <p class="text-muted small mb-1">
          {{formatNumber followers.total}} followers
        </p>
      {{/if}}

      <!-- Genre -->
      {{#if genres.[0]}}
        <p class="text-muted small mb-0 text-truncate-1">
          {{genres.[0]}}
        </p>
      {{/if}}

    </div>
  </div>
</a>