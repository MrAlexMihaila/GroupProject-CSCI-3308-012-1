<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Find Friends</h2>
    <form class="d-flex" method="GET" action="/friends">
      <input
        type="text"
        class="form-control me-2"
        name="search"
        placeholder="Search by username"
        value="{{search}}"
        aria-label="Search friends"
      />
      <button class="btn btn-outline-primary" type="submit">Search</button>
    </form>
  </div>

  {{#if users}}
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
      {{#each users}}
        <div class="col">
          <div
            class="card h-100 shadow-sm" role="link" tabindex="0" onclick="window.location.href='/profile/{{user_id}}'"
            onkeydown="if (event.key === 'Enter') window.location.href='/profile/{{user_id}}'" style="cursor: pointer;"
          >
            <div class="card-body d-flex flex-column">
              {{#if user_image_url}}
                <img src="{{user_image_url}}" class="card-img-top mb-3" alt="{{username}}'s profile picture" style="height: 300px; object-fit: cover;">
              {{else}}
                <img src="/resources/img/default-profile.png" class="card-img-top mb-3" alt="Default profile picture" style="height: 300px; object-fit: cover;">
              {{/if}}
              <h5 class="card-title">{{username}}</h5>
              <p class="card-text text-muted mb-1">Joined: {{created_at}}</p>
              <p class="card-text text-muted mb-3">Followers: {{followers_count}}</p>

              <form method="POST" action="/friends/add" class="mt-auto" onclick="event.stopPropagation();">
                <input type="hidden" name="userId" value="{{user_id}}" />
                <input type="hidden" name="search" value="{{search}}" />
                {{#if isFollowing}}
                  <button type="button" class="btn btn-secondary w-100" disabled>Added</button>
                {{else}}
                  <button type="submit" class="btn btn-primary w-100">Add</button>
                {{/if}}
              </form>
            </div>
          </div>
        </div>
      {{/each}}
    </div>
  {{else}}
    <div class="alert alert-info">No users found with that search term.</div>
  {{/if}}
</div>