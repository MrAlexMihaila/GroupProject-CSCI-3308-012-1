<div class="container profile-layout mt-4 mb-4">
  <h1 class="mb-4">Profile</h1>

  {{#if message}}
    <div class="alert alert-warning" role="alert">{{message}}</div>
  {{/if}}

  <!-- Profile Section -->
  <div class="row g-4 align-items-start">
    <div class="col-12 col-lg-4">
      <div class="card profile-user-card">
        <div class="card-body text-center">
          
          <!-- Profile Picture and Info -->
          <img
            src="{{#if profileUser.user_image_url}}{{profileUser.user_image_url}}{{else}}/resources/img/default-profile.png{{/if}}"
            alt="Profile Picture"
            class="rounded-circle mb-3 profile-avatar"
          >
          <h3 class="mb-1">{{#if profileUser}}{{profileUser.username}}{{else}}Unknown User{{/if}}</h3>

          <!-- Friend Count -->
          <p class="text-muted mb-0">{{friendCount}} friends</p>

          <!-- Follower Count -->
          <p class="text-muted mb-0">{{followerCount}} followers</p>

          {{#if isOwnProfile}}
            
            <!-- Form to upload new profile picture -->
            <form method="POST" action="/profile/upload-image" enctype="multipart/form-data" class="mt-3">
              <input
                type="file"
                id="profileImage"
                name="image"
                accept=".jpg,.jpeg,.png,.webp,.gif,image/jpeg,image/png,image/webp,image/gif"
                required
                style="display: none;"
                onchange="if (this.files.length) { this.form.submit(); }"
              >
              <button type="button" class="btn btn-purple" onclick="document.getElementById('profileImage').click();">
                Upload Profile Picture
              </button>
            </form>
          
          <!-- Display friend status !-->
          {{else if profileUser}}

            <!-- Only show friend status if user is logged in -->
            {{#if user}}
              {{#if isFriend}}
                <p class="text-muted mb-0">You and {{profileUser.username}} are friends.</p>
                
                <!-- Form to unfollow user -->
                <form method="POST" action="/friends/unfollow" class="mt-auto">
                  <input type="hidden" name="unfollowedId" value="{{profileUser.user_id}}" />
                  <button type="submit" class="btn btn-purple mt-3 mb-0">Unfollow</button>
                </form>

              {{else if isFollowing}}
                <!-- Form to unfollow user -->
                <form method="POST" action="/friends/unfollow" class="mt-auto">
                  <input type="hidden" name="unfollowedId" value="{{profileUser.user_id}}" />
                  <button type="submit" class="btn btn-purple mt-3 mb-0">Unfollow</button>
                </form>

              {{else}}
                <!-- Form to follow user -->
                <form method="POST" action="/friends/follow" class="mt-3">
                  <input type="hidden" name="userId" value="{{user.user_id}}">
                  <input type="hidden" name="followedId" value="{{profileUser.user_id}}">
                  <button type="submit" class="btn btn-purple">Follow</button>
                </form>
              {{/if}}

            {{/if}}

          {{/if}}
        </div>
      </div>
    </div>

    <!-- Reviews Section -->
    <div class="col-12 col-lg-8">
      <div class="card profile-reviews-card">
        <div class="card-body">
          <h4 class="mb-3">Reviews</h4>

          {{#if reviews.length}}
          
            {{#each reviews}}
              <a href="/song/{{this.song_id}}" class="text-decoration-none text-reset d-block">
                <div class="card mb-3 profile-review-card">
                  <div class="card-body">
                    <div class="d-flex gap-3 align-items-stretch">
                      <div class="rounded overflow-hidden" style="width: 90px; min-width: 90px;">
                        <img
                          src="{{this.image_url}}"
                          alt="{{this.song_title}} artwork"
                          class="w-100 h-100"
                          style="object-fit: cover;"
                        >
                      </div>
                      <div>
                        <h5 class="card-title">{{this.song_title}}</h5>
                        <p class="card-text">{{this.review_text}}</p>
                        <p class="card-text"><small class="text-muted">Rating: {{gradeFromRating this.rating}}</small></p>
                      </div>
                    </div>
                  </div>
                </div>
              </a>
            {{/each}}

          {{else}}
            <div class="review-placeholder">
              <p class="mb-0 text-muted">No reviews yet.</p>
            </div>
          {{/if}}

        </div>
      </div>
    </div>
  </div>
</div>
