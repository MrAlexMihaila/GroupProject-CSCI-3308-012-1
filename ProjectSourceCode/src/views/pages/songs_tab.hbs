<div class="container mt-4 songs-scroll-container">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Songs</h2>
  </div>

  <div class="mb-3">
    <h3 class="mb-2 position-sticky sticky-header" style="top:0; z-index:1;">Global Top Charts</h3>
    <div class="row-scroll songs-row-scroll row-1">
      {{#each topCharts}}
        <div class="col-2-4">
          {{> song_card}}
        </div>
      {{/each}}
    </div>
  </div>

  <div>
    <h3 class="mb-2 position-sticky sticky-header" style="top:0; z-index:1;">Classic Rock</h3>
    <div class="row-scroll songs-row-scroll row-4">
      {{#each popular}}
        <div class="col-2-4">
          {{> song_card}}
        </div>
      {{/each}}
    </div>
  </div>

</div>