<div class="container mt-4">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Songs</h2>
    <span class="text-muted small">{{song_list.length}} results</span>
  </div>

  <div class="mb-3">
    <h3 class="mb-2 position-sticky" style="top:0; background:#fff; z-index:1;">Top Charts</h3>
    <div class="row-scroll row-1">
      {{#each song_list}}
        <div class="col-2-4">
          {{> song_card}}
        </div>
      {{/each}}
    </div>
  </div>

  <div>
    <h3 class="mb-2 position-sticky" style="top:0; background:#ffffff; z-index:1;">Popular</h3>
    <div class="row-scroll row-4">
      {{#each song_list}}
        <div class="col-2-4">
          {{> song_card}}
        </div>
      {{/each}}
    </div>
  </div>

</div>