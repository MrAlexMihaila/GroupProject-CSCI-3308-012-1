<!--same as artists and songs pretty much-->

<div class="container mt-4">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Albums</h2>
  </div>

  <div class="mb-3">
    <h3 class="mb-2 position-sticky" style="top:0; background:#fff; z-index:1;">Top Albums</h3>
    <div class="row-scroll row-1">
      {{#each topAlbums}}
        <div class="col-2-4">
          {{> album_card}}
        </div>
      {{/each}}
    </div>
  </div>

  <div>
    <h3 class="mb-2 position-sticky" style="top:0; background:#ffffff; z-index:1;">Greatest Hits</h3>
    <div class="row-scroll row-4">
      {{#each popularAlbums}}
        <div class="col-2-4">
          {{> album_card}}
        </div>
      {{/each}}
    </div>
  </div>

</div>