<div class="genre-header-wrapper">
  <div class="genre-header-card">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
      <div>
        <h1 style="margin-left: 10px;">Explore Genres</h1>
        <p class="genre-header-copy mb-0" style="margin-left: 10px;">Search your favorite genre to discover top songs and artists.</p>
      </div>
      <form class="d-flex genre-search-form w-100 w-md-auto" method="GET" action="/genres">
        <input
          type="text"
          class="form-control"
          name="search"
          placeholder="Search by genre"
          value="{{search}}"
          aria-label="Search genres"
        />
        <button class="btn btn-purple ms-2 me-3" type="submit">Search</button>
      </form>
    </div>
  </div>
</div>

<div class="genre-page-body">
  {{#if search}}
    {{#if artists}}
      <div class="mb-4">
        <h3 class="mb-2" style="margin-left: 10px;">Top Artists in {{search}}</h3>
        <div class="row-scroll row-1 hidden">
          {{#each artists}}
            <div class="col-2-4">
              {{> artist_card}}
            </div>
          {{/each}}
        </div>
      </div>
    {{/if}}

    {{#if songs}}
      <div class="mb-4">
        <h3 class="mb-2" style="margin-left: 10px;">Top Songs in {{search}}</h3>
        <div class="row-scroll row-1">
          {{#each songs}}
            <div class="col-2-4">
              {{> song_card}}
            </div>
          {{/each}}
        </div>
      </div>
    {{/if}}

    {{#unless artists}}
      {{#unless songs}}
        <div class="alert alert-info">No artists or songs found for the genre "{{search}}".</div>
      {{/unless}}
    {{/unless}}
  {{else}}
  {{/if}}
</div>