<!-- Most of this is copy/pasted from the song page. -->
<div class="container-fluid" id="album-page" data-album-id="{{albumID}}">
    <div class="row">
        <div class="col-md-3 bg-light vh-100 p-4 ms-5">
            {{#if albumImages.[0].url}}
                <img src="{{albumImages.[0].url}}" class="img-fluid mb-3" alt="Album Art" />
            {{/if}}

            <h4>{{name}}</h4>

            <p class="text-muted">
                {{#each artists}}
                {{this.name}}{{#unless @last}}, {{/unless}}
                {{/each}}
            </p>

            {{#if login}}
                <button class="btn btn-primary mt-3" data-bs-toggle="modal" data-bs-target="#add_review_modal">
                    Add Review
                </button>
            {{else}}
                <button class="btn btn-primary mt-3">
                    Please login to add a review!
                </button>
            {{/if}}
        </div>
        <div class="col-md-7 p-4">
            <div class="row">
                <!-- Tracks -->
                <div class="col-md-6">
                    <h5>Tracks</h5>
                    <ul class="list-group">
                        {{#each tracks}}
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <a href="/songs_tab/{{this.id}}" class="text-decoration-none">
                                    {{this.name}}
                                </a>
                                <span class="text-muted">
                                    {{this.formattedDuration}}
                                </span>
                            </li>
                        {{/each}}
                    </ul>
                </div>
                <!-- Reviews -->
                <div class="col-md-6">
                    <h5>Community Ratings</h5>
                    <p>Insert album reviews here</p>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Review Modal -->
<div class="modal" tabindex="-1" id="add_review_modal">
    <div class="modal-dialog">
        <div class="modal-content">

            <!-- Header -->
            <div class="modal-header">
                <h5 class="modal-title">Add Album Review</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <!-- Body -->
            <div class="modal-body">
                <form id="album_review_form" onsubmit="return handleAlbumSubmit();">

                    <div class="mb-3">
                        <label for="review_rating" class="form-label">Rating</label>
                        <select class="form-select" id="review_rating">
                            <option value="rating_a">A</option>
                            <option value="rating_b">B</option>
                            <option value="rating_c">C</option>
                            <option value="rating_d">D</option>
                            <option value="rating_e">E</option>
                            <option value="rating_f">F</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="review_description" class="form-label">Review Description</label>
                        <input type="text" class="form-control"
                            id="review_description"
                            placeholder="Write your review here, if you want!">
                    </div>

                    <input type="hidden" id="album_id" value="{{albumID}}" />

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary"
                                data-bs-dismiss="modal">Close</button>

                        <button class="btn btn-primary" type="submit">
                            Save Review
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<script>
function handleAlbumSubmit() {
    const ratingMap = {
        A: 5,
        B: 4,
        C: 3,
        D: 2,
        E: 1,
        F: 0
    };

    const ratingLetter = document.getElementById("review_rating").value;
    const rating = ratingMap[ratingLetter];

    const description = document.getElementById("review_description").value;
    const albumID = document.getElementById("album_id").value;

    fetch("/addAlbumReview", {
        method: "POST",
        headers: {
            "Content-Type": "application/json"
        },
        body: JSON.stringify({
            rating: rating,
            description: description,
            albumID: albumID
        })
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            location.reload(); // refresh page to show new review
        } else {
            alert("Failed to add review");
        }
    })
    .catch(err => {
        console.error("Error:", err);
        alert("Something went wrong");
    });

    return false; // prevent default form submission
}
</script>