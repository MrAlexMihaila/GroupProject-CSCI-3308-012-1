{{! pretty much the same as songs.hbs just changed to artists}}

<div class="container mt-4">
  <div class="container mt-5 pb-5">

    {{#each artist_list}}

      {{!-- start a new row every 5 artists --}}
      {{#if (eq (mod @index 5) 0)}}

        {{!-- close previous row (if not first) --}}
        {{#if @index}}
          </div>
        {{/if}}

        <div class="d-flex justify-content-between align-items-center mb-4 mt-5">
          <h3 class="text-left m-0">Artists</h3>
          <a href="#" class="btn btn-sm btn-outline-primary">View More</a>
        </div>

        <div class="d-flex justify-content-start align-items-stretch gap-3"
             style="flex-wrap: nowrap; overflow-x: auto; overflow-y: hidden;
                    width: 100%; max-width: calc(100vw - 280px);">
      {{/if}}

      {{!-- artist card --}}
      {{> artist_card}}

    {{/each}}

    </div> {{!-- close last row --}}

  </div>
</div>