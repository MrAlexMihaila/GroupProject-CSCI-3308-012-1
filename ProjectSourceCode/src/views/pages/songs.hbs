<!--go back to the rows, so that we can display like different rows of top charts or recommended playlists-->
<!--need to add hover to songs-->

<div class="container mt-4">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Songs</h2>
    <span class="text-muted small">{{song_list.length}} results</span>
  </div>

  <div class="row-scroll row-1 mb-3">
    <h3 class="mb-2">Top Charts</h3>
    {{#each song_list}}
      <div class="col-2-4">
        {{> song_card}}
      </div>
    {{/each}}
  </div>

  <div class="row-scroll row-4">
    <h3 class="mb-2">Popular</h3>
    {{#each song_list}}
      <div class="col-2-4">
        {{> song_card}}
      </div>
    {{/each}}
  </div>

</div>