<div class="container mt-4">
    <div class="container mt-5 pb-5">
        {{#each song_list}}
            <!-- creates a new row every 5 songs -->
            <!-- in the future, each row will have a different spotify API call and we will not need this logic -->
            {{#if (eq (mod @index 5) 0)}}
                {{#if @index}}</div>{{/if}}
                <div class="d-flex justify-content-between align-items-center mb-4 mt-5">
                    <h3 class="text-left m-0">Row {{add (div @index 5) 1}}</h3>
                    <a href="#" class="btn btn-sm btn-outline-primary">View More</a>
                </div>
                <div class="d-flex justify-content-start align-items-stretch gap-3" style="flex-wrap: nowrap; 
                overflow-x: auto; overflow-y: hidden; width: 100%; max-width: calc(100vw - 280px);">
            {{/if}}
            {{> song_card}}
        {{/each}}
        </div>
    </div>
</div>