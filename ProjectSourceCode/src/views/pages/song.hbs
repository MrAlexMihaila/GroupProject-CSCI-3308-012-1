<div class="container-fluid" id="song-page" data-song-id="{{songID}}">
  <div class="row">
    <div class="col-md-3 bg-light vh-100 p-4 ms-5">
        {{#if albumImages.[0].url}}
            <img src="{{albumImages.[0].url}}" class="img-fluid mb-3" alt="Album Art" />
        {{/if}}
        <h4>{{name}}</h4>
        <p class="text-muted">
            {{#each artists}}
            {{this.name}}{{#unless @last}}, {{/unless}}
            {{/each}}
        </p>
        <p class="text-muted">
            <i class="bi bi-clock"></i> {{time}}
        </p>
        <p>
            <strong>Community Rating:</strong>
            {{#if songRating}}
                {{songRating}}
            {{else}}
                No ratings yet
            {{/if}}
        </p>
        
        {{#if login}}
            {{#if userReview}}
                <button class="btn btn-primary mt-3" data-bs-toggle="modal" data-bs-target="#add_review_modal">
                    Edit Review
                </button>
            {{else}}
                <button class="btn btn-primary mt-3" data-bs-toggle="modal" data-bs-target="#add_review_modal">
                    Add Review
                </button>
            {{/if}}
            
        {{else}}
            <button class="btn btn-primary mt-3" data-bs-toggle="modal">
                Please login to add a review!
            </button>
        {{/if}}
    </div>
    <div class="col-md-7 p-4">
        <div class="row">
            <div class="col-md-6">
                <h5>Community Reviews</h5>
                {{#if reviews.length}}
                    {{#each reviews}}
                        <div class="border p-2 mb-2">
                            <strong>{{username}}</strong>
                            <span class="ms-2">({{rating}}/5)</span>
                            <p>{{review_text}}</p>
                        </div>
                    {{/each}}
                {{else}}
                    <p>No reviews yet.</p>
                {{/if}}
            </div>

            <div class="col-md-6">
                <h5>Timestamp Comments</h5>
                <p>Insert Timestamp Comments here</p>
            </div>
        </div>
    </div>
  </div>
</div>

<!-- form to add a review, THIS IS NOT A SONG TIMESTAMP COMMENT -->
<!-- most of the structure was taken from lab 4 -->
<div class="modal" tabindex="-1" id="add_review_modal">
    <div class="modal-dialog">
        <div class="modal-content">

        <!-- Header -->
        <div class="modal-header">
            <h5 class="modal-title">Add Review</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>

        <!-- Body -->
        <div class="modal-body">
            <form id="event_form" onsubmit="return handleSubmit();">
                <div class="mb-3">
                    <label for="review_rating" class="form-label">Rating</label>
                    <select class="form-select" id="review_rating">
                        <option value="rating_a" {{#if (eq userReview.rating 5)}}selected{{/if}}>A</option>
                            <option value="rating_b" {{#if (eq userReview.rating 4)}}selected{{/if}}>B</option>
                            <option value="rating_c" {{#if (eq userReview.rating 3)}}selected{{/if}}>C</option>
                            <option value="rating_d" {{#if (eq userReview.rating 2)}}selected{{/if}}>D</option>
                            <option value="rating_e" {{#if (eq userReview.rating 1)}}selected{{/if}}>E</option>
                            <option value="rating_f" {{#if (eq userReview.rating 0)}}selected{{/if}}>F</option>
                    </select>
                </div>

                <!-- review description -->
                <div class="mb-3">
                    <label for="review_description" class="form-label">Review Description</label>
                    <input type="text" class="form-control" id="review_description"
                    value="{{#if userReview}}{{userReview.review_text}}{{/if}}"
                    placeholder="Write your review here, if you want!">
                </div>

                <!-- Footer -->
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">Close</button>

                    <button class="btn btn-primary" type="submit">
                        Save Review
                    </button>
                </div>

            </form>
        </div>
        </div>
    </div>
</div>