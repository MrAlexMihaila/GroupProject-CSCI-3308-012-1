<div class="container-fluid">
  <div class="row">
    <div class="col-md-3 bg-light vh-100 p-4 ms-5">
        {{#if albumImages.[0].url}}
            <img src="{{albumImages.[0].url}}" class="img-fluid mb-3" alt="Album Art" />
        {{/if}}
        <h4>{{name}}</h4>
        <p class="text-muted">
            {{#each artists}}
            {{this.name}}{{#unless @last}}, {{/unless}}
            {{/each}}
        </p>
        <p class="text-muted">
            <i class="bi bi-clock"></i> {{time}}
        </p>
        
        <button class="btn btn-primary mt-3" data-bs-toggle="modal" data-bs-target="#add_review_modal">
            {{#if login}}
                Add Review
            {{else}}
                Please login to add a review
            {{/if}}
        </button>
    </div>
    <div class="col-md-7 p-4">
        <div class="row">
            <div class="col-md-6">
                <h5>Lyrics</h5>
                <p>...</p>
            </div>

            <div class="col-md-6">
                <h5>Community Reviews</h5>
                <p>Insert reviews here</p>
            </div>
        </div>
    </div>
  </div>
</div>

<!-- form to add a review, THIS IS NOT A SONG TIMESTAMP COMMENT -->
<!-- most of the structure was taken from lab 4 -->
<div class="modal" tabindex="-1" id="add_review_modal">
    <div class="modal-dialog">
        <div class="modal-content">

        <!-- Header -->
        <div class="modal-header">
            <h5 class="modal-title">Add Review</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>

        <!-- Body -->
        <div class="modal-body">
            <form id="event_form" onsubmit="return handleSubmit();">

                <div class="mb-3">
                    <label for="review_number" class="form-label">Rating(0-5)</label>
                    <input type="number" class="form-control" id="review_number" placeholder="3">
                </div>

                <!-- review description -->
                <div class="mb-3">
                    <label for="review_description" class="form-label">Review Description</label>
                    <input type="text" class="form-control"
                        id="review_description"
                        placeholder="Write your review here, if you want!">
                </div>


                <!-- Footer -->
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">Close</button>

                    <button class="btn btn-primary" type="submit">
                        Save Review
                    </button>
                </div>

            </form>
        </div>
        </div>
    </div>
</div>